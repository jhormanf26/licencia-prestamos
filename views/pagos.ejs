<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Control de Pagos - Sistema de Préstamos</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Outfit', sans-serif; }
        body { background-color: #f8fafc; color: #334155; display: flex; }
        .main-content { margin-left: 260px; flex: 1; min-height: 100vh; display: flex; flex-direction: column; }
        .content-area { padding: 30px; flex: 1; position: relative; }
        
        .page-header { margin-bottom: 25px; }
        .page-title h2 { font-size: 24px; color: #1e293b; font-weight: 700; margin-bottom: 4px; display: flex; align-items: center; gap: 10px; }
        .page-title h2 i { color: #10b981; }
        .page-title p { color: #64748b; font-size: 14px; }

        .summary-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 25px; }
        .card { padding: 25px; border-radius: 12px; color: white; display: flex; flex-direction: column; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .card-title { font-size: 14px; font-weight: 600; opacity: 0.9; margin-bottom: 5px; }
        .card-value { font-size: 36px; font-weight: 700; }
        
        .bg-green { background-color: #10b981; }
        .bg-orange { background-color: #f59e0b; }
        .bg-purple { background-color: #8b5cf6; }

        .table-card { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid #f1f5f9; }
        .table-header-controls { display: flex; justify-content: space-between; margin-bottom: 15px; }
        .select-show { padding: 8px; border: 1px solid #e2e8f0; border-radius: 6px; outline: none;}
        .search-input { padding: 8px 12px; border: 1px solid #e2e8f0; border-radius: 6px; outline: none; width: 250px;}

        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 12px 10px; color: #000; font-size: 13px; font-weight: 700; border-bottom: 2px solid #f1f5f9; white-space: nowrap; }
        td { padding: 15px 10px; font-size: 13px; color: #475569; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
        .text-center { text-align: center; }
        
        .badge { padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
        .badge-pagado { background: #dcfce7; color: #166534; }
        .badge-pendiente { background: #fef08a; color: #854d0e; }
        .badge-anulado { background: #fee2e2; color: #b91c1c; }

        .paginator { display: flex; justify-content: space-between; align-items: center; margin-top: 20px; font-size: 13px; color: #64748b; }
        .paginator-btns { display: flex; gap: 5px; }
        .paginator-btns button { border: 1px solid #e2e8f0; background: white; padding: 6px 12px; cursor: pointer; border-radius: 4px; }
        .paginator-btns button.active { background: #2563eb; color: white; border-color: #2563eb; }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { path: '/pagos' }) %>
    <div class="main-content">
        <%- include('partials/header') %>
        <div class="content-area">
            <div class="page-header">
                <div class="page-title">
                    <h2><i class="fa-solid fa-file-invoice-dollar"></i> Control de Pagos</h2>
                    <p>Historial de cobros por licencias</p>
                </div>
            </div>

            <div class="summary-cards">
                <div class="card bg-green">
                    <span class="card-title">Total Cobrado</span>
                    <span class="card-value">S/ <%= parseFloat(totales.total_cobrado || 0).toFixed(2) %></span>
                </div>
                <div class="card bg-orange">
                    <span class="card-title">Pendiente de Cobro</span>
                    <span class="card-value">S/ <%= parseFloat(totales.total_pendiente || 0).toFixed(2) %></span>
                </div>
                <div class="card bg-purple">
                    <span class="card-title">Total Registros</span>
                    <span class="card-value"><%= totales.total_registros || 0 %></span>
                </div>
            </div>

            <div class="table-card">
                <div class="table-header-controls">
                    <div>
                        Mostrar 
                        <select class="select-show"><option>10</option></select>
                        registros
                    </div>
                    <div>
                        Buscar: <input type="text" class="search-input">
                    </div>
                </div>
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Empresa</th>
                            <th>Tipo Lic.</th>
                            <th>Monto</th>
                            <th>Método</th>
                            <th>Referencia</th>
                            <th>Fecha Pago</th>
                            <th>Estado</th>
                            <th>Acc.</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(pagos.length === 0) { %>
                            <tr>
                                <td colspan="9" class="text-center" style="padding: 30px; font-style: italic; color: #94a3b8;">
                                    <i class="fa-solid fa-inbox" style="font-size:24px;display:block;margin-bottom:8px;"></i>
                                    Sin registros de pagos aún
                                </td>
                            </tr>
                        <% } %>
                        <% pagos.forEach((pago, i) => { %>
                            <tr>
                                <td><%= i + 1 %></td>
                                <td><strong><%= pago.empresa %></strong></td>
                                <td><%= pago.tipo_licencia || '-' %></td>
                                <td><strong>S/ <%= parseFloat(pago.monto).toFixed(2) %></strong></td>
                                <td><%= pago.metodo_pago || 'Efectivo' %></td>
                                <td><%= pago.referencia || '-' %></td>
                                <td><%= pago.fecha_pago ? new Date(pago.fecha_pago).toLocaleDateString('es-PE') : '-' %></td>
                                <td><span class="badge badge-<%= pago.estado.toLowerCase() %>"><%= pago.estado %></span></td>
                                <td>
                                    <% if(pago.estado === 'Pendiente') { %>
                                        <form action="/pagos/marcar-pagado/<%= pago.id %>" method="POST" style="display:inline;">
                                            <button type="submit" style="background:#15803d;color:white;border:none;padding:5px 12px;border-radius:5px;cursor:pointer;font-size:12px;font-weight:600;">
                                                <i class="fa-solid fa-check"></i> Cobrado
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <% if(pago.licencia_id) { %>
                                            <a href="/licencias/ver/<%= pago.licencia_id %>" style="color:#2563eb;font-size:12px;"><i class="fa-solid fa-eye"></i> Ver</a>
                                        <% } else { %>
                                            <span style="color:#94a3b8;font-size:12px;">—</span>
                                        <% } %>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>

                <div class="paginator">
                    <span>Mostrando <strong><%= pagos.length %></strong> registro(s)</span>
                    <div class="paginator-btns">
                        <button disabled>Anterior</button>
                        <button class="active">1</button>
                        <button disabled>Siguiente</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
