<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Historial de Activaciones - Panel de Licencias</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Outfit', sans-serif; }
        body { background-color: #f8fafc; color: #334155; display: flex; }
        .main-content { margin-left: 260px; flex: 1; min-height: 100vh; display: flex; flex-direction: column; }
        .content-area { padding: 30px; flex: 1; }

        .page-title { margin-bottom: 25px; }
        .page-title h2 { font-size: 22px; color: #1e293b; font-weight: 700; display: flex; align-items: center; gap: 10px; }
        .page-title h2 i { color: #6366f1; }
        .page-title p { color: #64748b; font-size: 14px; margin-top: 4px; }

        .summary-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 25px; }
        .stat-card { background: white; border-radius: 12px; padding: 22px 25px; border: 1px solid #f1f5f9; box-shadow: 0 2px 8px rgba(0,0,0,0.04); display: flex; align-items: center; gap: 15px; }
        .stat-icon { width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
        .icon-blue { background: #dbeafe; color: #2563eb; }
        .icon-green { background: #dcfce7; color: #16a34a; }
        .icon-purple { background: #ede9fe; color: #7c3aed; }
        .stat-info p { font-size: 12px; color: #64748b; font-weight: 600; margin-bottom: 4px; }
        .stat-info h3 { font-size: 24px; font-weight: 700; color: #1e293b; }

        .table-card { background: white; border-radius: 12px; border: 1px solid #f1f5f9; box-shadow: 0 2px 8px rgba(0,0,0,0.04); overflow: hidden; }
        .table-top { display: flex; justify-content: space-between; align-items: center; padding: 18px 20px; border-bottom: 1px solid #f1f5f9; }
        .table-top h3 { font-size: 15px; font-weight: 700; color: #1e293b; }
        .search-box { padding: 8px 14px; border: 1px solid #e2e8f0; border-radius: 6px; outline: none; font-size: 13px; width: 220px; }
        .search-box:focus { border-color: #6366f1; }

        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 13px 16px; color: #475569; font-size: 12px; font-weight: 700; background: #f8fafc; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #e2e8f0; }
        td { padding: 14px 16px; font-size: 13px; color: #475569; border-bottom: 1px solid #f8fafc; vertical-align: middle; }
        tr:hover td { background: #fafafa; }
        tr:last-child td { border-bottom: none; }

        .ip-badge { font-family: monospace; background: #f1f5f9; padding: 3px 8px; border-radius: 4px; font-size: 12px; color: #334155; }
        .empresa-name { font-weight: 600; color: #1e293b; }
        .tipo-badge { background: #ede9fe; color: #7c3aed; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }

        .empty-state { text-align: center; padding: 60px 20px; color: #94a3b8; }
        .empty-state i { font-size: 48px; margin-bottom: 15px; display: block; }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { path: '/activaciones' }) %>
    <div class="main-content">
        <%- include('partials/header') %>
        <div class="content-area">

            <div class="page-title">
                <h2><i class="fa-solid fa-clock-rotate-left"></i> Historial de Activaciones</h2>
                <p>Registro de todos los arranques del sistema cliente con licencia válida.</p>
            </div>

            <div class="summary-cards">
                <div class="stat-card">
                    <div class="stat-icon icon-blue"><i class="fa-solid fa-bolt"></i></div>
                    <div class="stat-info">
                        <p>TOTAL ACTIVACIONES</p>
                        <h3><%= activaciones.length %></h3>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon icon-green"><i class="fa-solid fa-building"></i></div>
                    <div class="stat-info">
                        <p>EMPRESAS ÚNICAS</p>
                        <h3><%= [...new Set(activaciones.map(a => a.empresa_id))].length %></h3>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon icon-purple"><i class="fa-solid fa-network-wired"></i></div>
                    <div class="stat-info">
                        <p>IPs ÚNICAS</p>
                        <h3><%= [...new Set(activaciones.map(a => a.ip).filter(Boolean))].length %></h3>
                    </div>
                </div>
            </div>

            <div class="table-card">
                <div class="table-top">
                    <h3><i class="fa-solid fa-list" style="color:#6366f1;margin-right:8px;"></i> Registro de Conexiones</h3>
                    <input type="text" class="search-box" id="searchInput" placeholder="Buscar empresa, IP..." onkeyup="filtrar()">
                </div>
                <table id="tablaActivaciones">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Empresa</th>
                            <th>Tipo Licencia</th>
                            <th>IP del Cliente</th>
                            <th>Servidor</th>
                            <th>Fecha y Hora</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(activaciones.length === 0) { %>
                            <tr>
                                <td colspan="6">
                                    <div class="empty-state">
                                        <i class="fa-solid fa-satellite-dish"></i>
                                        <p style="font-size:15px;font-weight:600;color:#64748b;">Sin activaciones registradas aún</p>
                                        <p style="font-size:13px;margin-top:5px;">Las activaciones aparecerán aquí cuando el sistema cliente arranque con una licencia válida.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                        <% activaciones.forEach((act, i) => { %>
                            <tr>
                                <td style="color:#94a3b8;font-size:12px;"><%= i + 1 %></td>
                                <td><span class="empresa-name"><%= act.empresa || 'Empresa #' + act.empresa_id %></span></td>
                                <td><% if(act.tipo) { %><span class="tipo-badge"><%= act.tipo %></span><% } else { %><span style="color:#94a3b8;">—</span><% } %></td>
                                <td><span class="ip-badge"><%= act.ip || 'desconocida' %></span></td>
                                <td><%= act.servidor || '—' %></td>
                                <td>
                                    <% if(act.fecha) { %>
                                        <%= new Date(act.fecha).toLocaleDateString('es-PE') %>
                                        <span style="color:#94a3b8;margin-left:5px;font-size:12px;">
                                            <%= new Date(act.fecha).toLocaleTimeString('es-PE', {hour:'2-digit',minute:'2-digit'}) %>
                                        </span>
                                    <% } else { %>—<% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        function filtrar() {
            const q = document.getElementById('searchInput').value.toLowerCase();
            const filas = document.querySelectorAll('#tablaActivaciones tbody tr');
            filas.forEach(f => {
                f.style.display = f.innerText.toLowerCase().includes(q) ? '' : 'none';
            });
        }
    </script>
</body>
</html>
