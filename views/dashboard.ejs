<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Licencias</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Outfit', sans-serif; }
        body { background-color: #f8fafc; color: #334155; display: flex; }
        .main-content { margin-left: 260px; flex: 1; min-height: 100vh; display: flex; flex-direction: column; }
        .content-area { padding: 30px; flex: 1; }
        
        /* Typography */
        .page-title { margin-bottom: 25px; }
        .page-title h2 { font-size: 24px; color: #1e293b; font-weight: 700; margin-bottom: 4px; }
        .page-title p { color: #64748b; font-size: 14px; }

        /* Dashboard Cards */
        .summary-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .card { padding: 20px; border-radius: 12px; color: white; display: flex; flex-direction: column; position: relative; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .card-title { font-size: 13px; font-weight: 500; opacity: 0.9; margin-bottom: 10px; z-index: 1;}
        .card-value { font-size: 32px; font-weight: 700; z-index: 1;}
        .card-icon { position: absolute; right: 15px; top: 20px; font-size: 40px; opacity: 0.2; }
        
        .bg-purple { background-color: #8b5cf6; }
        .bg-green { background-color: #10b981; }
        .bg-orange { background-color: #f59e0b; }
        .bg-blue { background-color: #3b82f6; }

        /* Tables layout */
        .dashboard-tables { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .table-card { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid #f1f5f9; }
        .table-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid #f1f5f9; }
        .table-header h3 { font-size: 16px; color: #1e293b; font-weight: 600; display: flex; align-items: center; gap: 8px; }
        .table-header h3 i { color: #3b82f6; }
        .btn-outline { padding: 6px 12px; border: 1px solid #3b82f6; color: #3b82f6; border-radius: 20px; font-size: 12px; text-decoration: none; font-weight: 500; transition: all 0.2s; }
        .btn-outline:hover { background: #3b82f6; color: white; }
        
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 12px 10px; color: #000; font-size: 13px; font-weight: 700; border-bottom: 2px solid #f1f5f9; }
        td { padding: 12px 10px; font-size: 13px; color: #475569; border-bottom: 1px solid #f1f5f9; }
        .badge-active { background: #dcfce7; color: #166534; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
        .text-muted { text-align: center; color: #94a3b8; font-style: italic; padding: 20px; }
        
        /* New Button (top right) */
        .top-action-btn { position: absolute; right: 30px; top: 30px; background: #2563eb; color: white; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 14px; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 6px rgba(37, 99, 235, 0.2);}
        .top-action-btn:hover { background: #1d4ed8; }
        
        .alert-success { background: #d4edda; color: #155724; padding: 10px 15px; border-radius: 4px; margin-bottom: 20px; font-weight: 500; border-left: 4px solid #28a745;}
    </style>
</head>
<body>
    <%- include('partials/sidebar', { path: '/dashboard' }) %>
    <div class="main-content">
        <%- include('partials/header') %>
        <div class="content-area" style="position: relative;">
            <% if(success_msg && success_msg.length > 0) { %>
                <div class="alert-success"><i class="fa-solid fa-check-circle"></i> <%= success_msg %></div>
            <% } %>

            <div class="page-title">
                <h2>Dashboard</h2>
                <p>Resumen del sistema de licenciamiento</p>
            </div>
            
            <a href="/licencias/generar" class="top-action-btn"><i class="fa-solid fa-plus"></i> Nueva Licencia</a>

            <div class="summary-cards">
                <div class="card bg-purple">
                    <span class="card-title">Empresas Activas</span>
                    <span class="card-value"><%= stats.empresas %></span>
                    <i class="fa-solid fa-building card-icon"></i>
                </div>
                <div class="card bg-green">
                    <span class="card-title">Licencias Activas</span>
                    <span class="card-value"><%= stats.licencias %></span>
                    <i class="fa-solid fa-certificate card-icon"></i>
                </div>
                <div class="card bg-orange">
                    <span class="card-title">Por Vencer (30d)</span>
                    <span class="card-value"><%= stats.por_vencer %></span>
                    <i class="fa-solid fa-triangle-exclamation card-icon"></i>
                </div>
                <div class="card bg-blue">
                    <span class="card-title">Ingresos del Mes</span>
                    <span class="card-value">S/ <%= stats.ingresos.toFixed(2) %></span>
                    <i class="fa-solid fa-dollar-sign card-icon"></i>
                </div>
            </div>

            <div class="dashboard-tables">
                <div class="table-card">
                    <div class="table-header">
                        <h3><i class="fa-solid fa-circle"></i> Últimas Licencias</h3>
                        <a href="/licencias" class="btn-outline">Ver todas</a>
                    </div>
                    <table>
                        <thead>
                            <tr>
                                <th>Empresa</th>
                                <th>Tipo</th>
                                <th>Vence</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (ultimasLicencias.length === 0) { %>
                                <tr><td colspan="4" class="text-muted">Sin licencias recientes</td></tr>
                            <% } else { %>
                                <% ultimasLicencias.forEach(lic => { %>
                                    <tr>
                                        <td><%= lic.empresa %></td>
                                        <td><%= lic.tipo %></td>
                                        <td><%= lic.vence ? new Date(lic.vence).toLocaleDateString() : 'Sin límite' %></td>
                                        <td><span class="badge-active"><%= lic.estado %></span></td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <div class="table-card">
                    <div class="table-header">
                        <h3><i class="fa-solid fa-clock-rotate-left"></i> Últimas Activaciones</h3>
                        <a href="/activaciones" class="btn-outline">Ver todo</a>
                    </div>
                    <table>
                        <thead>
                            <tr>
                                <th>Empresa</th>
                                <th>Fecha</th>
                                <th>IP</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (ultimasActivaciones.length === 0) { %>
                                <tr><td colspan="3" class="text-muted">Sin activaciones aún</td></tr>
                            <% } else { %>
                                <% ultimasActivaciones.forEach(act => { %>
                                    <tr>
                                        <td><%= act.empresa %></td>
                                        <td><%= new Date(act.fecha).toLocaleString() %></td>
                                        <td><%= act.ip %></td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
