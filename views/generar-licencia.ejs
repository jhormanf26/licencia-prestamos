<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Generar Licencia - Sistema de Préstamos</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Outfit', sans-serif; }
        body { background-color: #f8fafc; color: #334155; display: flex; }
        .main-content { margin-left: 260px; flex: 1; min-height: 100vh; display: flex; flex-direction: column; }
        .content-area { padding: 30px; flex: 1; position: relative; max-width: 900px; }
        
        .btn-back { display: inline-flex; align-items: center; gap: 8px; color: #64748b; text-decoration: none; border: 1px solid #e2e8f0; padding: 8px 15px; border-radius: 6px; font-weight: 500; margin-bottom: 20px; transition: all 0.2s; background: white;}
        .btn-back:hover { background: #f1f5f9; }

        .page-title h2 { font-size: 20px; color: #1e293b; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
        .page-title h2 i { color: #10b981; }

        .form-card { background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid #f1f5f9; overflow: hidden; }
        .form-header { background: #15803d; color: white; padding: 15px 20px; font-weight: 600; font-size: 15px; display: flex; align-items: center; gap: 10px; }
        .form-body { padding: 30px; }

        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
        .form-group { margin-bottom: 15px; }
        .form-group.full { grid-column: 1 / -1; }
        
        .form-group label { display: block; font-size: 13px; font-weight: 600; color: #475569; margin-bottom: 8px; }
        .form-group label span { color: #ef4444; }
        .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 12px; border: 1px solid #e2e8f0; border-radius: 6px; outline: none; font-size: 14px; }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: #10b981; }
        .form-hint { font-size: 11px; color: #94a3b8; margin-top: 5px; }

        .info-box { background: #e0f2fe; border: 1px solid #bae6fd; padding: 15px; border-radius: 8px; font-size: 13px; color: #0284c7; display: flex; gap: 10px; margin-bottom: 20px; }
        .info-box i { margin-top: 2px; }

        .form-footer { display: flex; gap: 10px; padding-top: 10px; border-top: 1px solid #f1f5f9; margin-top: 20px; }
        .btn-submit { background: #15803d; color: white; border: none; padding: 12px 25px; border-radius: 6px; font-weight: 600; cursor: pointer; flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 15px;}
        .btn-submit:hover { background: #166534; }
        .btn-cancel { background: #64748b; color: white; border: none; padding: 12px 25px; border-radius: 6px; font-weight: 600; cursor: pointer; text-decoration: none; display: flex; align-items: center; justify-content: center;}
        .btn-cancel:hover { background: #475569; }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { path: '/licencias' }) %>
    <div class="main-content">
        <%- include('partials/header') %>
        <div class="content-area">
            <a href="/licencias" class="btn-back"><i class="fa-solid fa-arrow-left"></i> Volver</a>
            
            <div class="page-title">
                <h2><i class="fa-solid fa-circle-plus"></i> Generar Nueva Licencia</h2>
            </div>

            <div class="form-card">
                <div class="form-header">
                    <i class="fa-solid fa-circle"></i> Configurar Licencia
                </div>
                <div class="form-body">
                    <form action="/generar-licencia" method="POST">
                        <div class="form-group full">
                            <label>Empresa / EESS <span>*</span></label>
                            <select name="cliente_referencia" required>
                                <option value="">Seleccione una empresa</option>
                                <% empresas.forEach(emp => { %>
                                    <option value="<%= emp.id %>"><%= emp.razon_social %> (RUC: <%= emp.ruc %>)</option>
                                <% }) %>
                            </select>
                            <div class="form-hint">El RUC de la empresa es parte de la clave de licencia.</div>
                        </div>

                        <div class="form-grid">
                            <div class="form-group">
                                <label>Tipo de Período <span>*</span></label>
                                <select name="tipo" required>
                                    <option value="Demo / Prueba (Días)">Demo / Prueba (Días)</option>
                                    <option value="Mensual">Mensual</option>
                                    <option value="Anual">Anual</option>
                                    <option value="Perpetua">Perpetua</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Cantidad <span>*</span> (Ej: Días si es Demo)</label>
                                <input type="number" name="dias_vigencia" value="15" required>
                                <div class="form-hint">Si es oficial, déjalo vacío o usa 0.</div>
                            </div>

                            <div class="form-group">
                                <label>Fecha de Inicio <span>*</span></label>
                                <input type="date" name="fecha_inicio" value="<%= new Date().toISOString().split('T')[0] %>" required>
                            </div>
                            <div class="form-group">
                                <label>Fecha de Vencimiento</label>
                                <input type="text" id="fecha_vencimiento" disabled value="Calculado automáticamente">
                            </div>

                            <div class="form-group">
                                <label>Precio (<%= globalConfig.moneda %>) <span>*</span></label>
                                <input type="number" step="0.01" name="precio" value="0.00" required id="precio_input">
                                <div class="form-hint" id="precio_preview" style="color: #15803d; font-weight: 700; font-size: 13px;">$ 0,00</div>
                            </div>
                        </div>

                        <div class="form-group full">
                            <label>Notas / Observaciones</label>
                            <textarea name="notas" rows="3" placeholder="Ej: Incluye soporte técnico..."></textarea>
                        </div>

                        <div class="info-box">
                            <i class="fa-solid fa-circle-info"></i>
                            <div>
                                <strong>La clave de licencia se generará automáticamente</strong> con HMAC-SHA256 basado en el RUC, la empresa y la fecha de vencimiento. El sistema es <strong>100% offline</strong> - no requiere conexión a internet para la validación.
                            </div>
                        </div>

                        <div class="form-footer">
                            <button type="submit" class="btn-submit"><i class="fa-solid fa-key"></i> Generar Licencia</button>
                            <a href="/licencias" class="btn-cancel">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        const tipoEl = document.querySelector('select[name="tipo"]');
        const cantidadEl = document.querySelector('input[name="dias_vigencia"]');
        const inicioEl = document.querySelector('input[name="fecha_inicio"]');
        const vencimientoEl = document.getElementById('fecha_vencimiento');
        
        function calcularVencimiento() {
            const tipo = tipoEl.value;
            const cantidad = parseInt(cantidadEl.value) || 0;
            const inicio = new Date(inicioEl.value);
            
            // Fix timezone issue by adding hours
            inicio.setMinutes(inicio.getMinutes() + inicio.getTimezoneOffset());
            
            if (isNaN(inicio.getTime())) return;
    
            let vencimiento = new Date(inicio);
            
            if (tipo.includes('Demo') || tipo.includes('Días')) {
                vencimiento.setDate(inicio.getDate() + cantidad);
            } else if (tipo === 'Mensual') {
                vencimiento.setMonth(inicio.getMonth() + (cantidad || 1));
            } else if (tipo === 'Anual') {
                vencimiento.setFullYear(inicio.getFullYear() + (cantidad || 1));
            } else if (tipo === 'Perpetua') {
                vencimientoEl.type = 'text';
                vencimientoEl.value = 'Perpetua (Sin Vencimiento)';
                return;
            }
    
            vencimientoEl.type = 'date';
            vencimientoEl.value = vencimiento.toISOString().split('T')[0];
        }
    
        const precioInput = document.getElementById('precio_input');
        const precioPreview = document.getElementById('precio_preview');
        const monedaActual = '<%= globalConfig.moneda %>';

        function updatePrecioPreview() {
            const val = parseFloat(precioInput.value) || 0;
            const formatted = val.toLocaleString('es-CO', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            precioPreview.innerText = monedaActual + ' ' + formatted;
        }
    
        tipoEl.addEventListener('change', calcularVencimiento);
        cantidadEl.addEventListener('input', calcularVencimiento);
        inicioEl.addEventListener('change', calcularVencimiento);
        precioInput.addEventListener('input', updatePrecioPreview);
    
        // Initial calc
        calcularVencimiento();
        updatePrecioPreview();
    </script>
</body>
</html>
