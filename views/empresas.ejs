<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Empresas / EESS - Licencias</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Outfit', sans-serif; }
        body { background-color: #f8fafc; color: #334155; display: flex; }
        .main-content { margin-left: 260px; flex: 1; min-height: 100vh; display: flex; flex-direction: column; }
        .content-area { padding: 30px; flex: 1; position: relative; }
        
        .page-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 25px; }
        .page-title h2 { font-size: 24px; color: #1e293b; font-weight: 700; margin-bottom: 4px; display: flex; align-items: center; gap: 10px; }
        .page-title h2 i { color: #3b82f6; }
        .page-title p { color: #64748b; font-size: 14px; }
        .btn-primary { background: #2563eb; color: white; border: none; padding: 10px 20px; border-radius: 8px; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; text-decoration: none;}
        .btn-primary:hover { background: #1d4ed8; }

        .table-card { background: white; border-radius: 12px; padding: 25px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid #f1f5f9; }
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 12px 10px; color: #000; font-size: 13px; font-weight: 700; border-bottom: 2px solid #f1f5f9; }
        td { padding: 15px 10px; font-size: 13px; color: #475569; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
        .badge { padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
        .badge-activo { background: #dcfce7; color: #166534; }
        .badge-inactivo { background: #fee2e2; color: #b91c1c; }
        .ruc { color: #e11d48; font-family: monospace; font-size: 13px; }
        
        .actions-group { display: flex; gap: 5px; }
        .btn-action { width: 30px; height: 30px; border-radius: 4px; border: none; color: white; display: flex; justify-content: center; align-items: center; cursor: pointer; }
        .btn-action.view { background: #0ea5e9; }
        .btn-action.edit { background: #eab308; }
        .btn-action.delete { background: #ef4444; }

        /* Modal Styles */
        .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.5); align-items: center; justify-content: center; }
        .modal.active { display: flex; }
        .modal-content { background-color: #fefefe; padding: 25px; border-radius: 12px; width: 450px; max-width: 90%; box-shadow: 0 5px 25px rgba(0,0,0,0.2); }
        .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .modal-header h3 { font-size: 18px; color: #1e293b; }
        .close-modal { color: #aaa; font-size: 24px; font-weight: bold; cursor: pointer; border: none; background: none; }
        .close-modal:hover { color: #333; }
        
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; font-size: 13px; font-weight: 600; color: #475569; margin-bottom: 6px; }
        .form-group input, .form-group select { width: 100%; padding: 10px; border: 1px solid #e2e8f0; border-radius: 6px; outline: none; }
        .form-actions { display: flex; gap: 10px; margin-top: 25px; justify-content: flex-end; }
        .btn-cancel { background: #e2e8f0; color: #475569; padding: 10px 15px; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; }
        .btn-save { background: #2563eb; color: white; padding: 10px 15px; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { path: '/empresas' }) %>
    <div class="main-content">
        <%- include('partials/header') %>
        <div class="content-area">
            <div class="page-header">
                <div class="page-title">
                    <h2><i class="fa-solid fa-building"></i> Empresas / EESS</h2>
                    <p>Clientes registrados en el sistema de licenciamiento</p>
                </div>
                <button class="btn-primary" onclick="openModal('modalNueva')"><i class="fa-solid fa-plus"></i> Nueva Empresa</button>
            </div>

            <div class="table-card">
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Razón Social</th>
                            <th>RUC</th>
                            <th>Responsable</th>
                            <th>Email</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% empresas.forEach((emp, i) => { %>
                            <tr>
                                <td><%= i + 1 %></td>
                                <td><strong><%= emp.razon_social %></strong></td>
                                <td class="ruc"><%= emp.ruc %></td>
                                <td><%= emp.responsable || '-' %></td>
                                <td><%= emp.email || '-' %></td>
                                <td><span class="badge badge-<%= (emp.estado || 'activo').toLowerCase() %>"><%= emp.estado || 'Activo' %></span></td>
                                <td>
                                    <div class="actions-group">
                                        <button class="btn-action view" title="Ver" onclick="openViewModal('<%= emp.razon_social %>', '<%= emp.ruc %>', '<%= emp.responsable %>', '<%= emp.email %>', '<%= emp.estado %>')"><i class="fa-solid fa-eye"></i></button>
                                        <button class="btn-action edit" title="Editar" onclick="openEditModal('<%= emp.id %>', '<%= emp.razon_social %>', '<%= emp.ruc %>', '<%= emp.responsable %>', '<%= emp.email %>', '<%= emp.estado %>')"><i class="fa-solid fa-pen-to-square"></i></button>
                                        <button class="btn-action delete" title="Eliminar" onclick="confirmDelete('<%= emp.id %>')"><i class="fa-solid fa-trash"></i></button>
                                    </div>
                                    <form id="deleteForm-<%= emp.id %>" action="/empresas/eliminar/<%= emp.id %>" method="POST" style="display:none;"></form>
                                </td>
                            </tr>
                        <% }) %>
                        <% if(empresas.length === 0) { %>
                            <tr><td colspan="7" style="text-align:center;">No hay empresas registradas</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal Nueva Empresa -->
    <div id="modalNueva" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Nueva Empresa</h3>
                <button class="close-modal" onclick="closeModal('modalNueva')">&times;</button>
            </div>
            <form action="/empresas/nueva" method="POST">
                <div class="form-group">
                    <label>Razón Social *</label>
                    <input type="text" name="razon_social" required>
                </div>
                <div class="form-group">
                    <label>RUC *</label>
                    <input type="text" name="ruc" required>
                </div>
                <div class="form-group">
                    <label>Responsable</label>
                    <input type="text" name="responsable">
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="email">
                </div>
                <div class="form-actions">
                    <button type="button" class="btn-cancel" onclick="closeModal('modalNueva')">Cancelar</button>
                    <button type="submit" class="btn-save">Guardar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Editar Empresa -->
    <div id="modalEditar" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Editar Empresa</h3>
                <button class="close-modal" onclick="closeModal('modalEditar')">&times;</button>
            </div>
            <form id="formEditar" method="POST">
                <div class="form-group">
                    <label>Razón Social *</label>
                    <input type="text" id="edit_razon_social" name="razon_social" required>
                </div>
                <div class="form-group">
                    <label>RUC *</label>
                    <input type="text" id="edit_ruc" name="ruc" required>
                </div>
                <div class="form-group">
                    <label>Responsable</label>
                    <input type="text" id="edit_responsable" name="responsable">
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" id="edit_email" name="email">
                </div>
                <div class="form-group">
                    <label>Estado</label>
                    <select id="edit_estado" name="estado">
                        <option value="Activo">Activo</option>
                        <option value="Inactivo">Inactivo</option>
                    </select>
                </div>
                <div class="form-actions">
                    <button type="button" class="btn-cancel" onclick="closeModal('modalEditar')">Cancelar</button>
                    <button type="submit" class="btn-save">Actualizar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Ver Empresa -->
    <div id="modalVer" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Detalles de la Empresa</h3>
                <button class="close-modal" onclick="closeModal('modalVer')">&times;</button>
            </div>
            <div style="margin-bottom: 20px;">
                <p style="margin-bottom: 8px;"><strong>Razón Social:</strong> <span id="view_razon"></span></p>
                <p style="margin-bottom: 8px;"><strong>RUC:</strong> <span id="view_ruc" class="ruc"></span></p>
                <p style="margin-bottom: 8px;"><strong>Responsable:</strong> <span id="view_responsable"></span></p>
                <p style="margin-bottom: 8px;"><strong>Email:</strong> <span id="view_email"></span></p>
                <p><strong>Estado:</strong> <span id="view_estado"></span></p>
            </div>
            <div class="form-actions">
                <button type="button" class="btn-cancel" onclick="closeModal('modalVer')">Cerrar</button>
            </div>
        </div>
    </div>

    <script>
        function openModal(id) {
            document.getElementById(id).classList.add('active');
        }
        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }
        function openViewModal(razon, ruc, responsable, email, estado) {
            document.getElementById('view_razon').innerText = razon;
            document.getElementById('view_ruc').innerText = ruc;
            document.getElementById('view_responsable').innerText = responsable || '-';
            document.getElementById('view_email').innerText = email || '-';
            document.getElementById('view_estado').innerHTML = '<span class="badge badge-' + (estado || 'activo').toLowerCase() + '">' + (estado || 'Activo') + '</span>';
            openModal('modalVer');
        }
        function openEditModal(id, razon, ruc, responsable, email, estado) {
            document.getElementById('formEditar').action = '/empresas/editar/' + id;
            document.getElementById('edit_razon_social').value = razon;
            document.getElementById('edit_ruc').value = ruc;
            document.getElementById('edit_responsable').value = responsable;
            document.getElementById('edit_email').value = email;
            document.getElementById('edit_estado').value = estado || 'Activo';
            openModal('modalEditar');
        }
        function confirmDelete(id) {
            if(confirm('¿Estás seguro de eliminar esta empresa? Todas sus licencias se borrarán.')){
                document.getElementById('deleteForm-' + id).submit();
            }
        }
    </script>
</body>
</html>
